# ── Database ───────────────────────────────────────────────────────────────
# Local (Docker)
DATABASE_URL=postgresql://gridloan:gridloan_dev@localhost:5432/gridloan_waitlist

# Production (Railway, Supabase, Neon, Render)
DATABASE_URL=postgresql://gridloan:gridloan_dev@localhost:5432/gridloan_waitlist

# ── Server ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Security ───────────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500

# ── Rate limiting ──────────────────────────────────────────────────────────
# Max signup attempts per IP per 15-minute window
RATE_LIMIT_MAX=5
